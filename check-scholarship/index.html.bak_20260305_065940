                    <!-- Step 5: Document Upload (100%) -->
                    <div class="step" data-step="5">
                        <div class="step-title">
                            <i class="fas fa-file-upload"></i>
                            <h2>Document Upload</h2>
                            <p>Upload your documents for verification</p>
                        </div>
                        <div class="form-group">
                            <label>Upload Entrance Exam Scorecard (Optional, Max 5MB)</label>
                            <div class="file-upload" id="scorecardUpload" onclick="document.getElementById('scorecardInput').click()">
                                <i class="fas fa-cloud-upload-alt"></i>
                                <p>Click to upload scorecard</p>
                                <input type="file" id="scorecardInput" accept=".pdf,.jpg,.jpeg,.png" onchange="handleFileUpload(this, 'scorecardList', 'scorecardUpload', 'entranceScorecard')">
