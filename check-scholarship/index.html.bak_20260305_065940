    </div>

    <script>
        var API_BASE = 'https://counselor.ohcampus.com/api/scholarship-form';
        var currentStep = 1;
        var totalSteps = 5;
        var uploadedFiles = { marksCard: [], additionalMarks: [], scorecard: [] };
        
        // Capture UTM parameters
        var utmParams = {};
        function getUrlParams() {
            var params = new URLSearchParams(window.location.search);
            utmParams = {
                utm_source: params.get('utm_source') || '',
                utm_medium: params.get('utm_medium') || '',
                utm_campaign: params.get('utm_campaign') || '',
                counselor_id: params.get('counselor_id') || ''
            };
            // Store in localStorage to persist across page refreshes
            if (utmParams.counselor_id) {
                localStorage.setItem('scholarship_utm', JSON.stringify(utmParams));
            } else {
                var stored = localStorage.getItem('scholarship_utm');
                if (stored) utmParams = JSON.parse(stored);
            }
        }
        getUrlParams();

        document.addEventListener('DOMContentLoaded', function() {
            updateProgress();
            setTimeout(function() {
                loadStates();
                populateYears();
                loadFormData();
            }, 100);
            
            document.getElementById('step1Next').addEventListener('click', function() { if (validateStep(1)) { saveFormData(); nextStep(); } });
            document.getElementById('step2Prev').addEventListener('click', function() { saveFormData(); prevStep(); });
            document.getElementById('step2Next').addEventListener('click', function() { if (validateStep(2)) { saveFormData(); nextStep(); } });
            document.getElementById('step3Prev').addEventListener('click', function() { saveFormData(); prevStep(); });
            document.getElementById('step3Next').addEventListener('click', function() { if (validateStep(3)) { saveFormData(); nextStep(); } });
            document.getElementById('step4Prev').addEventListener('click', function() { saveFormData(); prevStep(); });
            document.getElementById('step4Next').addEventListener('click', function() { saveFormData(); nextStep(); });
            document.getElementById('step5Prev').addEventListener('click', function() { saveFormData(); prevStep(); });
            
            document.getElementById('stateSelect').addEventListener('change', loadDistricts);
            document.getElementById('collegeSearch').addEventListener('input', function() { searchColleges(this.value); });
        });

        function updateProgress() {
            var progress = currentStep * 20;
            document.getElementById('progressFill').style.width = progress + '%';
            document.getElementById('progressPercent').textContent = progress;
            document.getElementById('currentStep').textContent = currentStep;
            document.querySelectorAll('.step-dot').forEach(function(dot, index) {
                dot.classList.remove('active', 'completed');
                if (index + 1 < currentStep) dot.classList.add('completed');
                else if (index + 1 === currentStep) dot.classList.add('active');
            });
        }

        function showStep(step) {
            document.querySelectorAll('.step').forEach(function(s) { s.classList.remove('active'); });
            document.querySelector('.step[data-step="' + step + '"]').classList.add('active');
            currentStep = step;
            updateProgress();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function nextStep() { if (currentStep < totalSteps) showStep(currentStep + 1); }
        function prevStep() { if (currentStep > 1) showStep(currentStep - 1); }

        function validateStep(step) {
            var stepEl = document.querySelector('.step[data-step="' + step + '"]');
            var requiredFields = stepEl.querySelectorAll('input[required]:not([type="file"]), select[required]');
            var isValid = true;
            var missingFields = [];
            
            requiredFields.forEach(function(field) {
                if (!field.value.trim()) { 
                    field.classList.add('error'); 
                    isValid = false;
                    var label = field.closest('.form-group').querySelector('label');
                    if (label) missingFields.push(label.textContent.replace('*', '').trim());
                } else { 
                    field.classList.remove('error'); 
                }
            });
            
            // Check for file upload in step 2
            if (step === 2) {
                var marksCardList = document.getElementById('marksCardList');
                if (marksCardList.children.length === 0) {
                    isValid = false;
                    missingFields.push('Marks Card Upload');
                    document.getElementById('marksCardUpload').style.borderColor = 'var(--error)';
                } else {
                    document.getElementById('marksCardUpload').style.borderColor = 'var(--success)';
                }
            }
            
            if (!isValid) {
                alert('Please fill all required fields:\n- ' + missingFields.join('\n- '));
            }
            return isValid;
        }

        function selectRadio(el, name) {
            document.querySelectorAll('input[name="' + name + '"]').forEach(function(r) {
                r.closest('.radio-item').classList.remove('selected');
            });
            el.classList.add('selected');
            el.querySelector('input').checked = true;
        }

        function toggleCheckbox(el) {
            var cb = el.querySelector('input[type="checkbox"]');
            cb.checked = !cb.checked;
            el.classList.toggle('selected', cb.checked);
        }

        function populateYears() {
            var select = document.getElementById('passingYear');
            var currentYear = new Date().getFullYear();
            for (var y = currentYear + 1; y >= currentYear - 15; y--) {
                select.innerHTML += '<option value="' + y + '">' + y + '</option>';
            }
        }

        function loadStates() {
            fetch(API_BASE + '/getStates', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.status === 'success' && data.data) {
                        var select = document.getElementById('stateSelect');
                        var prefSelect = document.getElementById('prefStateSelect');
                        data.data.forEach(function(state) {
                            var opt = '<option value="' + state.name + '" data-id="' + state.id + '">' + state.name + '</option>';
                            select.innerHTML += opt;
                            prefSelect.innerHTML += opt;
                        });
                    }
                })
                .catch(function(e) { console.error('Error loading states:', e); });
        }

        function loadDistricts() {
            var stateSelect = document.getElementById('stateSelect');
            var stateId = stateSelect.options[stateSelect.selectedIndex].dataset.id;
            var districtSelect = document.getElementById('districtSelect');
            districtSelect.innerHTML = '<option value="">Select District</option>';
            if (!stateId) return;
            
            fetch(API_BASE + '/getDistricts', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ state_id: stateId }) 
            })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.status === 'success' && data.data) {
                        data.data.forEach(function(d) { 
                            districtSelect.innerHTML += '<option value="' + d.name + '">' + d.name + '</option>'; 
                        });
                    }
                })
                .catch(function(e) { console.error('Error loading districts:', e); });
        }

        function loadCoursesByStream() {
            var stream = document.getElementById('streamSelect').value;
            var courseSelect = document.getElementById('courseSelect');
            courseSelect.innerHTML = '<option value="">Select Course</option>';
            
            if (!stream) {
                courseSelect.innerHTML = '<option value="">Select Stream First</option>';
                return;
            }
            
            // Course categories mapped to streams
            var streamCourses = {
                'Engineering': ['B.Tech', 'B.E.', 'M.Tech', 'M.E.', 'B.Tech in Computer Science', 'B.Tech in Electronics', 'B.Tech in Mechanical', 'B.Tech in Civil', 'B.Tech in Electrical', 'B.Tech in Information Technology', 'B.Tech in Biotechnology', 'B.Tech in Chemical', 'B.Tech in Aerospace', 'B.Tech in Automobile', 'Diploma in Engineering'],
                'Medicine and Health Sciences': ['MBBS', 'BDS', 'BAMS', 'BHMS', 'B.Sc Nursing', 'M.Sc Nursing', 'MD', 'MS', 'DNB', 'BPT', 'MPT', 'B.Sc Allied Health Sciences', 'GNM', 'ANM'],
                'Management': ['BBA', 'MBA', 'BMS', 'BBM', 'PGDM', 'BCA', 'MCA', 'B.Com', 'M.Com', 'Executive MBA', 'MBA in Finance', 'MBA in Marketing', 'MBA in HR', 'MBA in Operations'],
                'Arts and Science': ['B.A.', 'M.A.', 'B.Sc', 'M.Sc', 'B.Sc Physics', 'B.Sc Chemistry', 'B.Sc Mathematics', 'B.Sc Biology', 'B.Sc Biotechnology', 'B.Sc Microbiology', 'B.A. Economics', 'B.A. English', 'B.A. Psychology', 'B.A. Sociology', 'B.A. Political Science'],
                'Pharmacy': ['B.Pharm', 'M.Pharm', 'D.Pharm', 'Pharm.D', 'B.Pharm + MBA', 'M.Pharm in Pharmaceutics', 'M.Pharm in Pharmacology'],
                'Agriculture': ['B.Sc Agriculture', 'M.Sc Agriculture', 'B.Tech Agricultural Engineering', 'B.Sc Horticulture', 'B.Sc Forestry', 'B.V.Sc', 'B.F.Sc'],
                'Paramedical': ['B.Sc MLT', 'B.Sc Radiology', 'B.Sc Optometry', 'B.Sc Dialysis Technology', 'B.Sc Operation Theatre', 'B.Sc Cardiac Care', 'B.Sc Respiratory Therapy', 'Diploma in Medical Lab Technology'],
                'Law': ['LLB', 'LLM', 'BA LLB', 'BBA LLB', 'B.Com LLB', 'B.Sc LLB'],
                'Education': ['B.Ed', 'M.Ed', 'D.El.Ed', 'B.P.Ed', 'M.P.Ed'],
                'Design and Architecture': ['B.Arch', 'M.Arch', 'B.Des', 'M.Des', 'B.Plan', 'Interior Design', 'Fashion Design', 'Graphic Design'],
                'Hotel Management': ['BHM', 'BHMCT', 'B.Sc Hotel Management', 'Diploma in Hotel Management', 'MBA in Hospitality'],
                'Computer Applications': ['BCA', 'MCA', 'B.Sc IT', 'M.Sc IT', 'B.Sc Computer Science', 'M.Sc Computer Science', 'PGDCA', 'B.Tech CSE']
            };
            
            var courses = streamCourses[stream] || [];
            courses.forEach(function(course) {
                courseSelect.innerHTML += '<option value="' + course + '">' + course + '</option>';
            });
        }

        function searchColleges(query) {
            var dropdown = document.getElementById('collegeDropdown');
            if (query.length < 3) { dropdown.style.display = 'none'; return; }
            
            fetch(API_BASE + '/getColleges', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ search: query }) 
            })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    dropdown.innerHTML = '';
                    if (data.status === 'success' && data.data && data.data.length > 0) {
                        dropdown.style.display = 'block';
                        data.data.slice(0, 10).forEach(function(c) {
                            var div = document.createElement('div');
                            div.className = 'college-dropdown-item';
                            div.textContent = c.name;
                            div.onclick = function() { 
                                document.getElementById('collegeSearch').value = c.name; 
                                dropdown.style.display = 'none'; 
                            };
                            dropdown.appendChild(div);
                        });
                    } else { dropdown.style.display = 'none'; }
                })
                .catch(function(e) { console.error('Error:', e); });
        }

        // Store uploaded file URLs
        var uploadedFileUrls = {
            marksCard: null,
            entranceScorecard: null
        };

        function handleFileUpload(input, listId, uploadBoxId, fileType) {
            var fileList = document.getElementById(listId);
            var uploadBox = uploadBoxId ? document.getElementById(uploadBoxId) : null;
            
            Array.from(input.files).forEach(function(file) {
                if (file.size > 5 * 1024 * 1024) { 
                    alert(file.name + ' exceeds 5MB limit.'); 
                    return; 
                }
                
                // Show uploading state
                var fileItem = document.createElement('div');
                fileItem.className = 'file-item';
                fileItem.id = 'file-' + Date.now();
                fileItem.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Uploading ' + file.name + '...';
                fileList.appendChild(fileItem);
                
                // Upload file to server
                var formData = new FormData();
                formData.append('file', file);
                
                fetch(API_BASE + '/uploadDocument', {
                    method: 'POST',
                    body: formData
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.status === 'success') {
                        // Store the URL
                        if (fileType === 'marksCard') {
                            uploadedFileUrls.marksCard = data.file_url;
                        } else if (fileType === 'entranceScorecard') {
                            uploadedFileUrls.entranceScorecard = data.file_url;
                        }
                        
                        // Update UI
                        fileItem.innerHTML = '<i class="fas fa-check-circle" style="color:var(--success)"></i> ' + file.name + ' <span class="remove" onclick="removeFile(this, \'' + listId + '\', \'' + (uploadBoxId || '') + '\', \'' + fileType + '\')"><i class="fas fa-times"></i></span>';
                        fileItem.dataset.url = data.file_url;
                        
                        if (uploadBox) {
                            uploadBox.style.borderColor = 'var(--success)';
                            uploadBox.style.background = 'rgba(34, 197, 94, 0.1)';
                        }
                    } else {
                        fileItem.innerHTML = '<i class="fas fa-exclamation-circle" style="color:var(--error)"></i> Upload failed: ' + (data.response_message || 'Error');
                        setTimeout(function() { fileItem.remove(); }, 3000);
                    }
                })
                .catch(function(e) {
                    console.error('Upload error:', e);
                    fileItem.innerHTML = '<i class="fas fa-exclamation-circle" style="color:var(--error)"></i> Upload failed';
                    setTimeout(function() { fileItem.remove(); }, 3000);
                });
            });
        }

        function removeFile(el, listId, uploadBoxId, fileType) {
            el.parentElement.remove();
            
            // Clear the stored URL
            if (fileType === 'marksCard') {
                uploadedFileUrls.marksCard = null;
            } else if (fileType === 'entranceScorecard') {
                uploadedFileUrls.entranceScorecard = null;
            }
            
            var fileList = document.getElementById(listId);
            if (fileList.children.length === 0 && uploadBoxId) {
                var uploadBox = document.getElementById(uploadBoxId);
                if (uploadBox) {
                    uploadBox.style.borderColor = '';
                    uploadBox.style.background = '';
                }
            }
        }

        function saveFormData() {
            var formData = {};
            var form = document.getElementById('scholarshipForm');
            var inputs = form.querySelectorAll('input, select');
            inputs.forEach(function(input) {
                if (input.type === 'checkbox') {
                    if (!formData[input.name]) formData[input.name] = [];
                    if (input.checked) formData[input.name].push(input.value);
                } else if (input.type === 'radio') {
                    if (input.checked) formData[input.name] = input.value;
                } else if (input.type !== 'file') {
                    formData[input.name] = input.value;
                }
            });
            localStorage.setItem('scholarshipFormData', JSON.stringify(formData));
        }

        function loadFormData() {
            var saved = localStorage.getItem('scholarshipFormData');
            if (!saved) return;
            var formData = JSON.parse(saved);
            Object.keys(formData).forEach(function(key) {
                var el = document.querySelector('[name="' + key + '"]');
                if (!el) return;
                if (el.type === 'checkbox') {
                    document.querySelectorAll('[name="' + key + '"]').forEach(function(cb) {
                        if (formData[key].includes(cb.value)) {
                            cb.checked = true;
                            cb.closest('.checkbox-item').classList.add('selected');
                        }
                    });
                } else if (el.type === 'radio') {
                    document.querySelectorAll('[name="' + key + '"]').forEach(function(r) {
                        if (r.value === formData[key]) {
                            r.checked = true;
                            r.closest('.radio-item').classList.add('selected');
                        }
                    });
                } else {
                    el.value = formData[key];
                }
            });
        }

        document.getElementById('scholarshipForm').addEventListener('submit', function(e) {
            e.preventDefault();
            var submitBtn = document.getElementById('submitBtn');
            submitBtn.innerHTML = '<span class="loading"></span> Submitting...';
            submitBtn.disabled = true;
            
            var formData = new FormData(this);
            var data = {};
            formData.forEach(function(value, key) { 
                if (key === 'entrance_exam') {
                    if (!data[key]) data[key] = [];
                    data[key].push(value);
                } else if (value) {
                    data[key] = value;
                }
            });
            if (data.entrance_exam) data.entrance_exam = data.entrance_exam.join(', ');
            
            // Add UTM parameters to submission
            if (utmParams.counselor_id) data.counselor_id = utmParams.counselor_id;
            if (utmParams.utm_source) data.utm_source = utmParams.utm_source;
            if (utmParams.utm_medium) data.utm_medium = utmParams.utm_medium;
            if (utmParams.utm_campaign) data.utm_campaign = utmParams.utm_campaign;
            
            // Add uploaded file URLs
            if (uploadedFileUrls.marksCard) data.marks_card_url = uploadedFileUrls.marksCard;
            if (uploadedFileUrls.entranceScorecard) data.entrance_scorecard_url = uploadedFileUrls.entranceScorecard;
            
            fetch(API_BASE + '/apply', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify(data) 
            })
                .then(function(r) { return r.json(); })
                .then(function(result) {
                    if (result.status === 'success') {
                        localStorage.removeItem('scholarshipFormData');
                        localStorage.removeItem('scholarship_utm');
                        document.getElementById('applicationId').textContent = result.application_id;
                        document.getElementById('scholarshipForm').style.display = 'none';
                        document.getElementById('successContainer').classList.add('show');
                        document.querySelector('.progress-container').style.display = 'none';
                    } else {
                        alert(result.message || 'Submission failed.');
                        submitBtn.innerHTML = '<i class="fas fa-check-circle"></i> Check My Scholarship Eligibility';
                        submitBtn.disabled = false;
                    }
                })
                .catch(function(e) {
                    alert('Network error. Please try again.');
                    submitBtn.innerHTML = '<i class="fas fa-check-circle"></i> Check My Scholarship Eligibility';
                    submitBtn.disabled = false;
                });
        });

        document.addEventListener('click', function(e) {
            if (!e.target.closest('#collegeSearch') && !e.target.closest('#collegeDropdown')) {
                document.getElementById('collegeDropdown').style.display = 'none';
            }
        });
    </script>

